TELEGRAM_BOT_TOKEN=replace_me
BOT_NAME=$YOURCOIN Radar
BRAND=$YOURCOIN

# Link templates. Use {ca} for the token contract address.
SCAN_URL_TEMPLATE=https://dexscreener.com/solana/{ca}
BUY_URL_TEMPLATE=https://jup.ag/swap/SOL-{ca}
CHART_URL_TEMPLATE=https://dexscreener.com/solana/{ca}

# Mock provider keeps the bot runnable without paid APIs. Replace provider code when ready.
DATA_PROVIDER=mock
DATA_FILE=./data/radar-store.json

# Owner / private Telegram backup.
# Send /id to the bot in private chat, then put that number in both values below.
BACKUP_CHAT_ID=
ADMIN_USER_IDS=
ALLOW_CHAT_ADMIN_BACKUP=true
BACKUP_INTERVAL_MINUTES=1440
BACKUP_ON_START=true
BACKUP_ON_SHUTDOWN=true
BACKUP_SKIP_UNCHANGED=true
ENABLE_RESTORE_COMMAND=true
MAX_BACKUP_BYTES=45000000

# Render/hosting keepalive. Workers already stay running, but this heartbeat
# proves the process is alive and can optionally ping a health URL.
KEEPALIVE_INTERVAL_MINUTES=5
KEEPALIVE_URL=
ENABLE_HEALTH_SERVER=false
HEALTH_HOST=0.0.0.0

# Alert timing.
POLL_TIMEOUT_SECONDS=30
ALERT_TICK_SECONDS=30
GROUP_DIGEST_MINUTES=60
USER_HOURLY_DIGEST_MINUTES=60
USER_DAILY_DIGEST_HOUR=9

# Optional testing command. When true, /demoalert emits sample alerts.
ENABLE_DEMO_COMMANDS=false
