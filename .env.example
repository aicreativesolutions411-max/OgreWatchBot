TELEGRAM_BOT_TOKEN=replace_me
BOT_NAME=Ogres Radar
BRAND=Ogres

# Link templates. Use {ca} for token contract addresses and {wallet} for wallets.
SCAN_URL_TEMPLATE=https://dexscreener.com/solana/{ca}
BUY_URL_TEMPLATE=https://jup.ag/swap/SOL-{ca}
CHART_URL_TEMPLATE=https://dexscreener.com/solana/{ca}
WALLET_URL_TEMPLATE=https://solscan.io/account/{wallet}

# Footer shown under bot messages.
SOCIAL_FOOTER_ENABLED=true
SOCIAL_FOOTER_TITLE=Powered by Ogres
SOCIAL_TELEGRAM_URL=https://t.me/ogrecoinonsol
SOCIAL_WEBSITE_URL=https://ogremode.com/
SOCIAL_TWITTER_URL=https://twitter.com/i/communities/1930265213917425858

# DexScreener gives live public market data. Use mock only for local offline testing.
DATA_PROVIDER=dexscreener
DATA_FILE=./data/radar-store.json
DATA_FALLBACK_FILE=/tmp/yourcoin-radar/radar-store.json
# Leave false on Render. Only set true if you have a working mounted /var/data disk.
ALLOW_VAR_DATA_FILE=false

# Owner / private Telegram backup.
# Send /id to the bot in private chat, then put that number in both values below.
BACKUP_CHAT_ID=
ADMIN_USER_IDS=
ALLOW_CHAT_ADMIN_BACKUP=true
BACKUP_ALLOW_PUBLIC_CHATS=false
BACKUP_INTERVAL_MINUTES=1440
BACKUP_ON_START=true
BACKUP_ON_SHUTDOWN=true
BACKUP_SKIP_UNCHANGED=true
ENABLE_RESTORE_COMMAND=true
MAX_BACKUP_BYTES=45000000

# Render/hosting keepalive. Web services must bind PORT, and this heartbeat
# pings the public Render URL unless KEEPALIVE_URL is set.
KEEPALIVE_INTERVAL_MINUTES=10
KEEPALIVE_URL=
ENABLE_HEALTH_SERVER=true
HEALTH_HOST=0.0.0.0

# Alert timing.
POLL_TIMEOUT_SECONDS=30
ALERT_TICK_SECONDS=30
COMMAND_GATE_MESSAGES=10
PANEL_REUSE_MINUTES=60
ENABLE_AUTO_CA_SCAN=false
ENABLE_IMMEDIATE_GROUP_ALERTS=false
MARKET_REFRESH_INTERVAL_SECONDS=60
DEXSCREENER_API_BASE=https://api.dexscreener.com
DEXSCREENER_SEARCH_QUERIES=SOL/USDC,SOL,pump,pumpfun,raydium,meteora,moonshot,bonk
DEXSCREENER_MAX_TOKENS=120
NEW_PAIR_DEFAULT_AGE_MINUTES=60
NEW_PAIR_MIN_LIQUIDITY_USD=5000
NEW_PAIR_FRESH_MIN_LIQUIDITY_USD=2500
NEW_PAIR_FRESH_MIN_VOLUME_USD=8000

# Quality filter for new pairs/trending/digests. Works without an API key using
# DexScreener heuristics; add Solana Tracker for deeper rug/bundler/insider flags.
MARKET_QUALITY_FILTER_ENABLED=true
MARKET_QUALITY_MIN_SCORE=62
MARKET_QUALITY_FRESH_MIN_LIQUIDITY_USD=2500
SOLANA_TRACKER_API_KEY=
SOLANA_TRACKER_API_BASE=https://data.solanatracker.io
SOLANA_TRACKER_RISK_ENABLED=true
SOLANA_TRACKER_MAX_RISK_SCORE=7

DELETE_WEBHOOK_ON_START=true
DROP_PENDING_UPDATES_ON_START=false
RESET_TELEGRAM_OFFSET_ON_START=true
GROUP_DIGEST_MINUTES=60
USER_HOURLY_DIGEST_MINUTES=60
USER_DAILY_DIGEST_HOUR=9

# Optional testing command. When true, /demoalert emits sample alerts.
ENABLE_DEMO_COMMANDS=false
